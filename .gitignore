# Frontend build output
dist/
dist-ssr/

# Dependencies
node_modules/

# Rust / Cargo
src-tauri/target/
**/*.rs.bk

# Tauri-generated files (regenerated on each build)
src-tauri/gen/schemas/
src-tauri/WixTools/
src-tauri/.tauri/

# rathole binary is supplied at runtime by the user — never vendored
src-tauri/binaries/
sidecar/
/rathole
/rathole.exe

# Local launcher runtime data (created next to the executable at runtime)
/server_conf/
/client_conf/
/launcher.json
logs/
*.log
npm-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.vs/
.zed/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Env (commit .env.example only)
.env
.env.local
.env.*.local
!.env.example

# Misc caches
*.tsbuildinfo
.eslintcache
.cache/
coverage/
